<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-cities-table" author="gmartins">
        <createTable tableName="cities">
            <column name="cod_cid" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="uf" type="varchar(2)"/>
        </createTable>
    </changeSet>

    <changeSet id="004-create-clients-table" author="gmartins">
        <createTable tableName="clients">
            <column name="cod_parc" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome_parc" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="razao_social" type="varchar(255)"/>
            <column name="cgc_cpf" type="varchar(20)"/>
            <column name="person_type" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="classif_icms" type="varchar(5)"/>
            <column name="cod_cid" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="clients"
                baseColumnNames="cod_cid"
                constraintName="fk_clients_city"
                referencedTableName="cities"
                referencedColumnNames="cod_cid"/>
    </changeSet>

</databaseChangeLog>
